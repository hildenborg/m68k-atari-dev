diff --git a/libgloss/m68k/atari/atari-setmode.c b/libgloss/m68k/atari/atari-setmode.c
new file mode 100644
index 000000000..0deb99f10
--- /dev/null
+++ b/libgloss/m68k/atari/atari-setmode.c
@@ -0,0 +1,89 @@
+/*
+	Copyright (C) 2026 Mikael Hildenborg
+	SPDX-License-Identifier: BSD-2-Clause
+*/
+#include <stddef.h>
+#include <errno.h>
+#include "atari-traps.h"
+
+#ifndef _FBINARY
+#define _FBINARY 0x10000
+#define O_BINARY _FBINARY
+#endif
+#ifndef _FTEXT
+#define _FTEXT 0x20000
+#define O_TEXT _FTEXT
+#endif
+
+#define ATARI_O_BINARY 1
+
+#define MAX_FILE_HANDLES 128
+
+unsigned char static_file_chunk[MAX_FILE_HANDLES] = {0};
+
+int getMode(short f)
+{
+	unsigned char atariMode;
+	if (f < MAX_FILE_HANDLES)
+	{
+		atariMode = static_file_chunk[f];
+	}
+	else
+	{
+		errno = EINVAL;
+		return -1;
+	}
+
+	int mode = (atariMode & ATARI_O_BINARY) ? O_BINARY : O_TEXT;
+
+	return mode;
+}
+
+int setMode(short f, int mode)
+{
+	if ((mode & (O_BINARY | O_TEXT)) != 0)
+	{
+		/*
+			We only support binary and text mode for now. The rest is ignored.
+			We also assume that if binary mode is not specifically set, then the file is in text mode.
+		*/
+		unsigned char atariMode = (mode & O_BINARY) ? ATARI_O_BINARY : 0;
+		if (f < MAX_FILE_HANDLES)
+		{
+			static_file_chunk[f] = atariMode;
+		}
+		else
+		{
+			errno = EINVAL;
+			return -1;
+		}
+	}
+}
+
+int _atari_getmode(short f)
+{
+	if (f < 0)
+	{
+		errno = EINVAL;
+		return -1;
+	}
+	return getMode(f);
+}
+
+int _atari_setmode(short f, int mode)
+{
+	if (f < 0)
+	{
+		errno = EINVAL;
+		return -1;
+	}
+	int oldMode = getMode(f);
+	if (oldMode != -1)
+	{
+		if (setMode(f, mode) == -1)
+		{
+			return -1;
+		}
+	}
+	return oldMode;
+}
