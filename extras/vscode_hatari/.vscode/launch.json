	"version": "2.0.0",
	"configurations": [
		{
			"type": "gdbtarget",
			"request": "attach",
			"name": "cdt debug",
			"program": "${workspaceFolder}/build/${env:TARGET_NAME}",
			"preLaunchTask": "Copy to HD",
